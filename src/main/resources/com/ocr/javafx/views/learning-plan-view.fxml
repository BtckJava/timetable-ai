<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="30.0" style="-fx-background-color: #F8FAFC; -fx-padding: 40;" stylesheets="@../style/learning-plan.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.views.LearningPlanController">

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Learning Plans" textFill="#111827">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnNewPlan" onAction="#handleNewPlan" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 24; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(79,70,229,0.3), 10, 0, 0, 4);" text="+ New Plan">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="flowPanePlans" hgap="30.0" vgap="30.0" />
        </content>
    </ScrollPane>
</VBox>