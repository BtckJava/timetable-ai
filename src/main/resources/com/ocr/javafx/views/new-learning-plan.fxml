<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.views.NewLearningPlanController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="15.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Button fx:id="btnBack" style="-fx-background-color: transparent; -fx-cursor: hand;" text="←" textFill="#1e293b">
            <font><Font name="System Bold" size="20.0" /></font>
        </Button>
        <Label text="New Learning Plan" textFill="#0f172a">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnCreate" style="-fx-background-color: transparent; -fx-text-fill: #2563EB; -fx-cursor: hand;" text="Create Plan">
            <font><Font name="System Bold" size="14.0" /></font>
        </Button>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="NEVER">
        <VBox spacing="18.0">
            <VBox spacing="8.0">
                <Label style="-fx-font-weight: bold; -fx-font-size: 11;" text="PLAN TITLE" textFill="#64748B" />
                <TextField fx:id="txtTitle" promptText="e.g., Mastering Spring Boot" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 10;" />
            </VBox>

            <VBox spacing="8.0">
                <Label style="-fx-font-weight: bold; -fx-font-size: 11;" text="DOMAIN" textFill="#64748B" />
                <TextField fx:id="txtDomain" promptText="e.g., Software Engineering" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 10;" />
            </VBox>

            <VBox spacing="8.0">
                <Label style="-fx-font-weight: bold; -fx-font-size: 11;" text="OVERALL GOAL" textFill="#64748B" />
                <TextArea fx:id="txtGoal" prefHeight="100.0" promptText="Describe what you want to achieve..." style="-fx-control-inner-background: #F1F5F9; -fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 5;" wrapText="true" />
            </VBox>

            <HBox spacing="20.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 11;" text="DURATION (DAYS)" textFill="#64748B" />
                    <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 5;">
                        <Button onAction="#decrementDays" style="-fx-background-color: transparent; -fx-cursor: hand;" text="−" />
                        <Label fx:id="lblDuration" style="-fx-font-weight: bold;" text="14" />
                        <Button onAction="#incrementDays" style="-fx-background-color: transparent; -fx-cursor: hand;" text="+" />
                    </HBox>
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 11;" text="INTENSITY" textFill="#64748B" />
                    <ComboBox fx:id="comboIntensity" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 3;" />
                </VBox>
            </HBox>

            <VBox spacing="8.0">
                <HBox spacing="10.0" />
                <FlowPane fx:id="flowPaneSkills" hgap="8.0" vgap="8.0" />
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
