<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.views.ProfileController">
    <children>
        <VBox layoutX="37.0" layoutY="20.0" spacing="20" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="37.0" AnchorPane.rightAnchor="23.0" AnchorPane.topAnchor="20.0">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1),10,0,0,3);" HBox.hgrow="ALWAYS">
                    <StackPane>
                  <ImageView fx:id="imgAva" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                    </StackPane>
                    <VBox prefHeight="80.0" prefWidth="240.0" spacing="5">
                  <TextField fx:id="txtName" />
                        <Label fx:id="lblEmail" style="-fx-text-fill: gray;" text="nhi@gmail.com" />
                  <Label />
                               <Button fx:id="btnEditProfile" onAction="#handleEditProfile" style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 20;" text="Edit Profile" />
                    </VBox>
                </HBox>
            </HBox>
            <HBox spacing="20">
                <VBox spacing="5" style="-fx-background-color: #74b9ff; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: white;" text="Learning Hours" />
                    <Label fx:id="lblHours" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-font-weight: bold;" text="156" />
                </VBox>
                <VBox spacing="5" style="-fx-background-color: #55efc4; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: white;" text="Completed Plans" />
                    <Label fx:id="lblPlans" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-font-weight: bold;" text="12" />
                </VBox>
                <VBox spacing="5" style="-fx-background-color: #ffeaa7; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: black;" text="Current Streak" />
                    <Label fx:id="lblStreak" style="-fx-font-size: 18px; -fx-text-fill: black; -fx-font-weight: bold;" text="7" />
                </VBox>
                <VBox spacing="5" style="-fx-background-color: #fab1a0; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: white;" text="Skills Learned" />
                    <Label fx:id="lblSkills" style="-fx-font-size: 18px; -fx-text-fill: white; -fx-font-weight: bold;" text="24" />
                </VBox>
            </HBox>
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1),10,0,0,3);">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Achievements" />
                <HBox spacing="15">
                    <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #f1f2f6; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="⚡" />
                        <Label style="-fx-font-weight: bold;" text="Quick Learner" />
                        <Label fx:id="txtQuickLearner" style="-fx-text-fill: gray;" text="Completed your first plan" wrapText="true" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #f1f2f6; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="🔥" />
                        <Label style="-fx-font-weight: bold;" text="7-Day Streak" />
                        <Label fx:id="txtStreak" style="-fx-text-fill: gray;" text="Studied 7 days in a row" wrapText="true" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #f1f2f6; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="🏆" />
                        <Label style="-fx-font-weight: bold;" text="Master" />
                        <Label fx:id="txtMaster" style="-fx-text-fill: gray;" text="Learned 20+ skills" wrapText="true" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
