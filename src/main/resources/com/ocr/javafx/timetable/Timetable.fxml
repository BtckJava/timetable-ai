<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="600.0" prefWidth="960.0" stylesheets="@../style/timetable.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.timetable.TimetableController">

    <top>
        <VBox spacing="10.0" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="12.0" left="14.0" right="14.0" top="12.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="14.0">
                <Button mnemonicParsing="false" onAction="#onBackWeekClicked" text="&lt; Tuần trước" />
                <Label fx:id="monthYearLabel" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Tuần: …" />
                <Button mnemonicParsing="false" onAction="#onNextWeekClicked" text="Tuần tới &gt;" />
                <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #475569; -fx-font-weight: 600;" text="Learning plan" />
                    <ComboBox fx:id="planCombo" prefWidth="220.0" promptText="Chọn plan" />
                </HBox>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button fx:id="btnGenerateAi" mnemonicParsing="false" onAction="#onGenerateAi" text="Tạo lịch bằng AI" />
                <Button fx:id="btnSaveDb" mnemonicParsing="false" onAction="#onSaveToDb" text="Lưu Database" />
                <Button fx:id="btnAddManual" mnemonicParsing="false" onAction="#onAddManual" text="Thêm thủ công" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
            <ScrollPane fx:id="timetableScroll" fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" pannable="true" vbarPolicy="AS_NEEDED">
                <content>
                    <GridPane fx:id="timetableGrid" hgap="2.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" vgap="2.0">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                    </GridPane>
                </content>
            </ScrollPane>
            <ProgressIndicator fx:id="loadingIndicator" maxHeight="72.0" maxWidth="72.0" mouseTransparent="true" visible="false" StackPane.alignment="CENTER" />
        </StackPane>
    </center>
</BorderPane>
