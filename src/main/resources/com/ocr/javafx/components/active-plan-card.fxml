<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ocr.javafx.controller.components.ActivePlansCardController"
            prefWidth="300" prefHeight="120"
            style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e0e0e0;">

    <VBox spacing="8"
          AnchorPane.topAnchor="10"
          AnchorPane.leftAnchor="12"
          AnchorPane.rightAnchor="12"
          AnchorPane.bottomAnchor="10">

        <!-- Title -->
        <Label fx:id="titleLabel"
               style="-fx-text-fill: #1a1a1a; -fx-font-size: 16; -fx-font-weight: bold;" />

        <!-- Goal -->
        <Label fx:id="goalLabel"
               style="-fx-text-fill: #666666; -fx-font-size: 12;" />

        <!-- Progress -->
        <ProgressBar fx:id="progressBar"
                     prefWidth="260"
                     progress="0.0" />

        <!-- Bottom row -->
        <HBox spacing="10">
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #2196F3; -fx-font-size: 11;" />
        </HBox>

    </VBox>

</AnchorPane>