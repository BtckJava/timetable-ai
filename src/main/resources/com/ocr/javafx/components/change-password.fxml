<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="450.0" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15;" stylesheets="@../style/main.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.components.ChangePasswordController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <VBox alignment="CENTER" spacing="10">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Đổi mật khẩu" />
        <Label style="-fx-text-fill: #6b7280;" text="Vui lòng nhập mật khẩu mới cho tài khoản của bạn" />
    </VBox>

    <VBox spacing="15">
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Mật khẩu hiện tại" />
            <PasswordField fx:id="oldPasswordField" prefHeight="45.0" promptText="Nhập mật khẩu hiện tại" styleClass="auth-input" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Mật khẩu mới" />
            <PasswordField fx:id="newPasswordField" prefHeight="45.0" promptText="Nhập mật khẩu mới" styleClass="auth-input" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Xác nhận mật khẩu" />
            <PasswordField fx:id="confirmPasswordField" prefHeight="45.0" promptText="Xác nhận mật khẩu mới" styleClass="auth-input" />
        </VBox>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-font-size: 13px;" textFill="RED" wrapText="true" />

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-background-radius: 8;" text="Hủy" />
        <Button fx:id="btnSave" defaultButton="true" onAction="#handleSave" prefHeight="40.0" prefWidth="140.0" styleClass="auth-button" text="Lưu thay đổi" />
    </HBox>
</VBox>