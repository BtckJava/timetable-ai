<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane styleClass="global-font" stylesheets="@../style/global.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.components.SidebarController">

    <VBox maxWidth="240.0" minWidth="240.0" prefWidth="240.0" styleClass="sidebar-root" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <stylesheets>
            <URL value="@../style/sidebar.css" />
        </stylesheets>

        <!-- LOGO -->
        <AnchorPane prefHeight="120.0">
            <ImageView fitHeight="120.0" fitWidth="240.0" preserveRatio="true">
                <Image url="@../image/sidebarLogo.png" />
            </ImageView>
        </AnchorPane>

        <Separator />

        <!-- BUTTONS -->
        <Button maxWidth="1.7976931348623157E308" onAction="#handleDashboard" styleClass="sidebar-button" text="Dashboard">
            <graphic>
                <ImageView fitHeight="29.0" fitWidth="25.0" preserveRatio="true">
                    <Image url="@../image/dashboardIcon.png" />
                </ImageView>
            </graphic>
            <VBox.margin>
                <Insets left="10.0" right="10.0" top="10.0" />
            </VBox.margin>
        </Button>

        <Button maxWidth="1.7976931348623157E308" onAction="#handleTimetable" styleClass="sidebar-button" text="Timetable">
            <graphic>
                <ImageView fitHeight="29.0" fitWidth="25.0" preserveRatio="true">
                    <Image url="@../image/timetableIcon.png" />
                </ImageView>
            </graphic>
            <VBox.margin>
                <Insets left="10.0" right="10.0" top="5.0" />
            </VBox.margin>
        </Button>

        <Button maxWidth="1.7976931348623157E308" onAction="#handleLearningPlans" styleClass="sidebar-button" text="Learning Plans">
            <graphic>
                <ImageView fitHeight="29.0" fitWidth="25.0" preserveRatio="true">
                    <Image url="@../image/planIcon.png" />
                </ImageView>
            </graphic>
            <VBox.margin>
                <Insets left="10.0" right="10.0" top="5.0" />
            </VBox.margin>
        </Button>

        <Button maxWidth="1.7976931348623157E308" onAction="#handleProfile" styleClass="sidebar-button" text="Profile">
            <graphic>
                <ImageView fitHeight="29.0" fitWidth="25.0" preserveRatio="true">
                    <Image url="@../image/profileIcon.png" />
                </ImageView>
            </graphic>
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
            </VBox.margin>
        </Button>

    </VBox>
</AnchorPane>
