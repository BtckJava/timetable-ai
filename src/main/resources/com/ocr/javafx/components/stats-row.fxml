<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="125.0" prefWidth="737.0" spacing="10" stylesheets="@../style/statsRow.css, @../style/main.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.components.StatsRowController">

    <children>

        <HBox prefHeight="117.0" prefWidth="0.0" styleClass="base-box, stats-box-bar-learning" HBox.hgrow="ALWAYS">
         <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="stats-title" text="Learning Hours" VBox.vgrow="ALWAYS" />
                  <Label fx:id="learningHoursLabel" alignment="TOP_LEFT" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="stats-value" text="0" VBox.vgrow="ALWAYS" />
            </children>
            <HBox.margin>
               <Insets left="10.0" top="10.0" />
            </HBox.margin>
         </VBox>
        </HBox>

        <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="117.0" prefWidth="0.0" styleClass="base-box, stats-box-bar-complete" HBox.hgrow="ALWAYS">
         <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="stats-title" text="Completed Plans" VBox.vgrow="ALWAYS" />
                  <Label fx:id="completedPlansLabel" alignment="TOP_LEFT" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="stats-value" text="0" VBox.vgrow="ALWAYS" />
            </children>
            <HBox.margin>
               <Insets left="10.0" top="10.0" />
            </HBox.margin>
         </VBox>
        </HBox>

        <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="117.0" prefWidth="0.0" styleClass="base-box, stats-box-bar-plans" HBox.hgrow="ALWAYS">
         <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="stats-title" text="In Progress" VBox.vgrow="ALWAYS" />
                  <Label fx:id="inProgressLabel" alignment="TOP_LEFT" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="stats-value" text="0" VBox.vgrow="ALWAYS" />
            </children>
            <HBox.margin>
               <Insets left="10.0" top="10.0" />
            </HBox.margin>
         </VBox>
        </HBox>

        <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="117.0" prefWidth="0.0" styleClass="base-box, stats-box-bar-progress" HBox.hgrow="ALWAYS">
         <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="stats-title" text="Goal Progress" VBox.vgrow="ALWAYS" />
                  <Label fx:id="progressLabel" alignment="TOP_LEFT" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="stats-value" text="0%" VBox.vgrow="ALWAYS" />
            </children>
            <HBox.margin>
               <Insets left="10.0" top="10.0" />
            </HBox.margin>
         </VBox>
        </HBox>

    </children>

    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>

</HBox>
