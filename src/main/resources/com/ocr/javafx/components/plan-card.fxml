<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox fx:id="rootVBox" prefWidth="420.0" spacing="20.0" styleClass="plan-card-root" stylesheets="@../style/plan-card.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocr.javafx.controller.components.PlanCardController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="lblTitle" styleClass="plan-title" text="Advanced JavaScript" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnDelete" styleClass="btn-delete" onAction="#handleDelete">
            <graphic>
                <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../image/deleteIcon.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
    </HBox>

    <Label fx:id="lblGoal" styleClass="text-muted" text="Master advanced concepts in JavaScript..." wrapText="true" />

    <VBox spacing="8.0">
        <HBox>
            <Label styleClass="text-muted" text="Progress" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblProgressPercent" styleClass="progress-percent" text="65%" />
        </HBox>
        <ProgressBar fx:id="progressBar" maxWidth="1.7976931348623157E308" progress="0.65" styleClass="plan-progress-bar" />
    </VBox>

    <HBox spacing="20.0" styleClass="time-box">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="time-label-title" text="Duration" />
            <Label fx:id="lblDuration" styleClass="time-label-value" text="30 days" />
        </VBox>
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="time-label-title" text="Remaining" />
            <Label fx:id="lblRemaining" styleClass="time-label-value" text="14 days" />
        </VBox>
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="time-label-title" text="Started" />
            <Label fx:id="lblStarted" styleClass="time-label-value" text="2026-02-12" />
        </VBox>
    </HBox>

    <Label fx:id="lblIntensity" styleClass="intensity-label" text="High Intensity" />

    <FlowPane fx:id="flowPaneSkills" hgap="10.0" vgap="10.0" />

    <Separator style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;" />

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Button fx:id="btnViewDetails" styleClass="btn-ai" text="Xem chi tiết" />
        <ProgressIndicator fx:id="progressLoading" prefHeight="20.0" prefWidth="20.0" visible="false" />
    </HBox>
</VBox>