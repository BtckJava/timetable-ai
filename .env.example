# Sao chép thành file .env và điền giá trị (file .env không commit — đã có trong .gitignore)

# --- PostgreSQL (bắt buộc cho Hibernate) ---
DB_URL=jdbc:postgresql://localhost:5432/AiTimetable
DB_USER=postgres
DB_PASSWORD=

# --- Hibernate (tùy chọn) ---
HIBERNATE_HBM2DDL_AUTO=update
HIBERNATE_SHOW_SQL=false

# --- OpenRouter AI (tùy chọn) ---
# Dùng một trong hai tên (ưu tiên OPENROUTER_API_KEY)
OPENROUTER_API_KEY=
API_KEY=
